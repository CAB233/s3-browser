{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommitTypeAll(chore)",
    "github>Omochice/renovate-config:deno"
  ],
  "labels": ["dependencies"],
  "postUpgradeTasks": {
    "commands": ["npx -y deno install"],
    "fileFilters": ["deno.lock"],
    "executionMode": "branch",
    "installTools": {
      "node": {}
    }
  }
}
