{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommitTypeAll(chore)",
    "github>Omochice/renovate-config:deno"
  ],
  "labels": [
    "dependencies"
  ],
  "postUpgradeTasks": {
    "commands": [
      "npm install -g deno",
      "deno install"
    ],
    "fileFilters": [
      "deno.lock"
    ],
    "executionMode": "branch"
  }
}
